{
  "name": "netmcp",
  "version": "1.0.0",
  "description": "Monorepo of MCP servers for networking intelligence",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "bash test-all.sh",
    "test:coverage": "nyc bash test-all.sh",
    "test:integration": "bash test-integration.sh",
    "test:integration:coverage": "nyc bash test-integration.sh",
    "test:oui": "cd packages/oui-lookup && npm test",
    "test:rfc": "cd packages/rfc-search && npm test",
    "test:nvd": "cd packages/nvd-network-cves && npm test",
    "test:fcc": "cd packages/fcc-devices && npm test",
    "test:3gpp": "cd packages/threegpp-specs && npm test",
    "coverage": "nyc report --reporter=text --reporter=html",
    "coverage:check": "nyc check-coverage",
    "coverage:report": "nyc report --reporter=html && open coverage/index.html",
    "lint": "eslint packages/*/src/**/*.js",
    "lint:fix": "eslint --fix packages/*/src/**/*.js",
    "lint:workspaces": "npm run lint --workspaces --if-present",
    "update-oui": "cd packages/oui-lookup && npm run update-db",
    "start:oui": "cd packages/oui-lookup && npm start",
    "start:rfc": "cd packages/rfc-search && npm start",
    "start:nvd": "cd packages/nvd-network-cves && npm start",
    "start:fcc": "cd packages/fcc-devices && npm start",
    "start:3gpp": "cd packages/threegpp-specs && npm start"
  },
  "keywords": [
    "mcp",
    "networking",
    "security",
    "oui",
    "rfc",
    "nvd",
    "cve",
    "fcc",
    "3gpp",
    "monorepo"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cheenu1092-oss/netmcp"
  },
  "author": "Cheenu (cheenu1092@gmail.com)",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-plugin-jsdoc": "^62.8.0",
    "nyc": "^18.0.0"
  }
}
