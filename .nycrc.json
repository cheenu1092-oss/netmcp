{
  "all": true,
  "include": [
    "packages/*/src/**/*.js"
  ],
  "exclude": [
    "packages/*/test/**",
    "packages/*/.actor/**",
    "node_modules/**",
    "coverage/**",
    ".nyc_output/**"
  ],
  "reporter": [
    "text",
    "text-summary",
    "html",
    "lcov"
  ],
  "report-dir": "./coverage",
  "temp-dir": "./.nyc_output",
  "check-coverage": false,
  "lines": 80,
  "statements": 80,
  "functions": 80,
  "branches": 70,
  "watermarks": {
    "lines": [70, 90],
    "statements": [70, 90],
    "functions": [70, 90],
    "branches": [60, 80]
  }
}
